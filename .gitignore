# ==========================================
# Python Byte-compiled / Optimized Cache Files
# ==========================================
# When Python runs your scripts, it compiles them into bytecode (.pyc) to load faster next time.
# These are environment-specific and do not belong on GitHub.
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# Large Model Weights (Automatically Ignored)
# ==========================================
# These files are extremely large (3.24 GB and 188 MB) and exceed GitHub's 100 MB limits.
# run_v1_inference.py will download them automatically if they are missing.
ArrayDPS/model_ckpt.pt
usef_tse_code/chkpt/chkpt/
usef_tse_code/chkpt/.cache/

# ==========================================
# Compressed Archives
# ==========================================
# Backups and zipped workspaces are ignored to keep the repository lightweight.
*.zip

# ==========================================
# Temporary Execution Buffers
# ==========================================
# Directories created dynamically during run inference (like chunked audio buffers).
v1_temp_run/

# ==========================================
# Operating System files
# ==========================================
# System-specific metadata files generated by Windows/macOS.
.DS_Store
Thumbs.db

# ==========================================
# local Editor / IDE Settings
# ==========================================
# Editor configurations (VS Code, PyCharm) that shouldn't be forced on others.
.vscode/
.idea/
