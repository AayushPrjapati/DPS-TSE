<mxfile host="Electron" modified="2026-07-18T11:20:00.000Z" agent="5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/21.2.8 Chrome/112.0.5615.165 Electron/24.2.0 Safari/537.36" version="21.2.8" type="device">
  <diagram id="proposed-tse-flow-symbols" name="Page-1">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="1" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Acoustic Mixture -->
        <mxCell id="y_mix" value="$$y_{\text{mix}}$$" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1.2;fillColor=#f9f9f9;strokeColor=#333333;fontFamily=Times New Roman;fontSize=14;" parent="1" vertex="1">
          <mxGeometry x="40" y="80" width="110" height="50" as="geometry" />
        </mxCell>
        
        <!-- Enrollment Cue -->
        <mxCell id="c_s" value="$$c_s$$" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1.2;fillColor=#f9f9f9;strokeColor=#333333;fontFamily=Times New Roman;fontSize=14;" parent="1" vertex="1">
          <mxGeometry x="40" y="180" width="110" height="50" as="geometry" />
        </mxCell>
        
        <!-- Discriminative Model -->
        <mxCell id="disc" value="$$f_{\phi}(\cdot)$$" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.2;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Times New Roman;fontSize=14;" parent="1" vertex="1">
          <mxGeometry x="180" y="130" width="130" height="50" as="geometry" />
        </mxCell>
        
        <!-- ydisc -->
        <mxCell id="ydisc" value="$$y_{\text{disc}}$$" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1.2;fillColor=#f9f9f9;strokeColor=#333333;fontFamily=Times New Roman;fontSize=14;" parent="1" vertex="1">
          <mxGeometry x="340" y="130" width="110" height="50" as="geometry" />
        </mxCell>
        
        <!-- Mask Generator -->
        <mxCell id="mask" value="$$M$$" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.2;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Times New Roman;fontSize=14;" parent="1" vertex="1">
          <mxGeometry x="340" y="230" width="110" height="55" as="geometry" />
        </mxCell>
        
        <!-- Masked Mixture -->
        <mxCell id="masked_mix" value="$$(1 - M) \odot y_{\text{mix}}$$" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1.2;fillColor=#f9f9f9;strokeColor=#333333;fontFamily=Times New Roman;fontSize=14;" parent="1" vertex="1">
          <mxGeometry x="470" y="230" width="130" height="55" as="geometry" />
        </mxCell>
        
        <!-- Likelihood Block -->
        <mxCell id="likelihood" value="$$\mathcal{L}_{\text{guidance}}$$" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.2;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Times New Roman;fontSize=14;" parent="1" vertex="1">
          <mxGeometry x="630" y="230" width="110" height="55" as="geometry" />
        </mxCell>
        
        <!-- Prior Block (DM) -->
        <mxCell id="prior" value="$$s_{\theta}(x_t, t)$$" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.2;fillColor=#e1d5e7;strokeColor=#b85450;fontFamily=Times New Roman;fontSize=14;" parent="1" vertex="1">
          <mxGeometry x="480" y="130" width="110" height="50" as="geometry" />
        </mxCell>
        
        <!-- Posterior Score Update -->
        <mxCell id="posterior" value="$$\nabla_{x_t} \log p_t(x_t | \cdot)$$" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=1.2;fillColor=#e1d5e7;strokeColor=#b85450;fontFamily=Times New Roman;fontSize=14;" parent="1" vertex="1">
          <mxGeometry x="620" y="130" width="130" height="50" as="geometry" />
        </mxCell>
        
        <!-- Output -->
        <mxCell id="output" value="$$x_0$$" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=1.5;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=Times New Roman;fontSize=14;" parent="1" vertex="1">
          <mxGeometry x="780" y="130" width="110" height="50" as="geometry" />
        </mxCell>
        
        <!-- Connections -->
        <!-- y_mix -> disc -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#000000;strokeWidth=1;" parent="1" source="y_mix" target="disc" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- c_s -> disc -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#000000;strokeWidth=1;" parent="1" source="c_s" target="disc" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- disc -> ydisc -->
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#000000;strokeWidth=1;" parent="1" source="disc" target="ydisc" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- ydisc -> mask -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#000000;strokeWidth=1;" parent="1" source="ydisc" target="mask" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- ydisc -> prior -->
        <mxCell id="e5" value="Noise Init" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#000000;strokeWidth=1;fontFamily=Times New Roman;fontSize=10;" parent="1" source="ydisc" target="prior" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- mask -> masked_mix -->
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#000000;strokeWidth=1;" parent="1" source="mask" target="masked_mix" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- y_mix -> masked_mix -->
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#000000;strokeWidth=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="y_mix" target="masked_mix" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="150" y="40" />
              <mxPoint x="450" y="40" />
              <mxPoint x="450" y="258" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- masked_mix -> likelihood -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#000000;strokeWidth=1;" parent="1" source="masked_mix" target="likelihood" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- likelihood -> posterior -->
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#000000;strokeWidth=1;" parent="1" source="likelihood" target="posterior" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- prior -> posterior -->
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#000000;strokeWidth=1;" parent="1" source="prior" target="posterior" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- posterior -> output -->
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#000000;strokeWidth=1.2;" parent="1" source="posterior" target="output" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
